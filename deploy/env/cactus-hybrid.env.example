# Bearer key expected from cloud_translate_api (ASL_CLOUD_API_KEY must match this)
ASL_CACTUS_SERVICE_API_KEY=replace-me

# Hugging Face OpenAI-compatible endpoint (without trailing /chat/completions)
# Example: https://api-inference.huggingface.co/v1
ASL_HF_OPENAI_BASE_URL=https://api-inference.huggingface.co/v1
ASL_HF_TOKEN=hf_xxx

# Proof fields
ASL_CACTUS_MODEL_VERSION=2026-05-11
